# Server port (Render injects PORT automatically)
PORT=3001

# Comma-separated list of allowed CORS origins (Render frontend URL)
CORS_ORIGIN=http://localhost:5173

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# JWT signing secret (generate a strong random string)
JWT_SECRET=generate-a-random-secret-here

# Turso database (for production, remove for local SQLite file)
# TURSO_DATABASE_URL=libsql://your-database-name.turso.io
# TURSO_AUTH_TOKEN=eyJ...your-turso-auth-token
